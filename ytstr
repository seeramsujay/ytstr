# Player Controller
# ==============================================================================

class YtstrPlayer:
    def __init__(self, playlist_url: str, shuffle: bool, mix: bool, light_mix: bool, crossfade_sec: float = 3.0):
        self.playlist_url = playlist_url
        self.shuffle = shuffle
        self.mix = mix
        self.light_mix = light_mix
        self.engine = DecisionEngine()
        self.crossfade_ms = int(crossfade_sec * 1000)
        
        self.playlist: List[Dict] = []
        global CACHE_DIR
        
        # E05 Fix: Startup Sweep for Stale SHM Dirs
        shm_base = "/dev/shm"
        if os.path.exists(shm_base):
            for d in os.listdir(shm_base):
                if d.startswith("ytstr_"):
                    try:
                        pid_str = d.split("_")[1]
                        os.kill(int(pid_str), 0)
                    except ProcessLookupError:
                        shutil.rmtree(os.path.join(shm_base, d), ignore_errors=True)
                    except Exception: pass

        CACHE_DIR = os.path.join(shm_base, f"ytstr_{os.getpid()}")
        os.makedirs(CACHE_DIR, exist_ok=True)
        self.cache_dir = CACHE_DIR
        self.raw_dir = os.path.join(self.cache_dir, "raw")
        self.mix_dir = os.path.join(self.cache_dir, "mixed")
        os.makedirs(self.raw_dir, exist_ok=True)
        os.makedirs(self.mix_dir, exist_ok=True)
        
        self.ipc_socket = os.path.join(self.cache_dir, "mpv_ipc")
        self.mpv_process = None
        self._quit_flag = False
        
        # State tracking
        self.downloaded_idx = -1
        self.mixed_idx = -1
        self.mpv_appended_idx = -1
        self.playing_idx = 0
        self.last_transition_type: str = ""  # For UI display
        
        # In-memory Pydub segments for overlaps
        self.cached_raw_audio: Dict[int, AudioSegment] = {}
        self.pending_overlap: Optional[AudioSegment] = None

    def fetch_playlist(self):
        info("Fetching playlist...")
        ydl_opts = {'extract_flat': True, 'quiet': True}
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            res = ydl.extract_info(self.playlist_url, download=False)
            if 'entries' in res:
                for entry in res['entries']:
                    if entry.get('id'):
                        self.playlist.append({
                            'id': entry['id'],
                            'title': entry.get('title', 'Unknown Title')
                        })
            else:
                self.playlist.append({'id': res['id'], 'title': res.get('title', 'Unknown Title')})
        
        if not self.playlist: die("Could not fetch playlist or playlist is empty.")
        success(f"Found {len(self.playlist)} videos")
        
        if self.shuffle:
            warn("Shuffling playlist...")
            random.shuffle(self.playlist)

    def download_worker(self):
        """Continuously downloads tracks up to 2 ahead of the mixed index."""
        while not self._quit_flag and self.downloaded_idx < len(self.playlist) - 1:
            if self.downloaded_idx <= self.mixed_idx + 2:
                target_idx = self.downloaded_idx + 1
                video_id = self.playlist[target_idx]['id']
                path = os.path.join(self.raw_dir, f"{target_idx}.opus")
                
                if not os.path.exists(path):
                    ydl_opts = {
                        'format': 'bestaudio',
                        'outtmpl': path,
                        'quiet': True,
                        'no_warnings': True,
                        'noprogress': True
                    }
                    try:
                        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                            ydl.download([f"https://www.youtube.com/watch?v={video_id}"])
                    except Exception: pass
                
                self.downloaded_idx = target_idx
            else:
                time.sleep(0.5)

    def mix_worker(self):
        """Lazily trims silences, mixes overlaps using Pydub, and exports sequentially."""
        while not self._quit_flag and self.mixed_idx < len(self.playlist) - 1:
            target_idx = self.mixed_idx + 1
            
            # E03 Fix: Backpressure - don't bake too far ahead
            if target_idx > self.playing_idx + 2:
                time.sleep(1)
                continue

            # E03 Fix: Garbage Collection - clean old baked tracks
            gc_idx = self.playing_idx - 1
            if gc_idx >= 0:
                old_wav = os.path.join(self.mix_dir, f"{gc_idx}_out.wav")
                old_raw = os.path.join(self.raw_dir, f"{gc_idx}.opus")
                if os.path.exists(old_wav):
                    try: os.remove(old_wav)
                    except Exception: pass
                if os.path.exists(old_raw):
                    try: os.remove(old_raw)
                    except Exception: pass
            
            # We need the current track downloaded
            if self.downloaded_idx < target_idx:
                time.sleep(0.5)
                continue
                
            # If mixing, we ALSO need the NEXT track downloaded unless it's the last track
            is_last = target_idx == (len(self.playlist) - 1)
            if self.mix and not is_last and self.downloaded_idx < target_idx + 1:
                time.sleep(0.5)
                continue

            try:
                # Load current track (either from raw or cache from previous iteration)
                if target_idx in self.cached_raw_audio:
                    s_current = self.cached_raw_audio.pop(target_idx)
                else:
                    path_curr = os.path.join(self.raw_dir, f"{target_idx}.opus")
                    s_current = AudioSegment.from_file(path_curr)
                    if self.mix: s_current = trim_to_energy(s_current)
                
                # Prepend the second-half of the overlap from the previous transition!
                if getattr(self, 'pending_overlap', None) is not None:
                    s_current = self.pending_overlap + s_current
                    self.pending_overlap = None
                
                if not self.mix or is_last:
                    # No crossfade logic needed for the very last track or NO-MIX
                    out_path = os.path.join(self.mix_dir, f"{target_idx}_out.wav")
                    s_current.export(out_path, format="wav")
                    self.mixed_idx = target_idx
                    continue
                
                # We are mixing. Load next track.
                path_next = os.path.join(self.raw_dir, f"{target_idx+1}.opus")
                s_next = AudioSegment.from_file(path_next)
                s_next = trim_to_energy(s_next)
                
                # Create the overlap using the Decision Engine
                fade_ms = self.crossfade_ms
                if self.light_mix:
                    trans_type = "fade"
                else:
                    trans_type = self.engine.select_transition(s_current, s_next)
                
                self.last_transition_type = trans_type
                print(f"{DIM}  -> Transition [{target_idx}->{target_idx+1}]: {trans_type}{NC}", file=sys.stderr)
                overlap, eff_fade = apply_transition(trans_type, s_current, s_next, fade_ms)
                
                half_fade = eff_fade // 2
                
                if eff_fade > 0:
                    out_chunk = s_current[:-eff_fade] + overlap[:half_fade]
                    self.pending_overlap = overlap[half_fade:]
                    self.cached_raw_audio[target_idx+1] = s_next[eff_fade:]
                else:
                    out_chunk = s_current
                    self.pending_overlap = None
                    self.cached_raw_audio[target_idx+1] = s_next
                    
                out_path = os.path.join(self.mix_dir, f"{target_idx}_out.wav")
                out_chunk.export(out_path, format="wav")
                
                self.mixed_idx = target_idx
                
            except Exception as e:
                # If processing fails, mark as mixed to skip stalling
                self.mixed_idx = target_idx

    def mpv_ipc_command(self, cmd: List[str]):
        """Dispatches JSON command to running MPV socket."""
        if not os.path.exists(self.ipc_socket): return
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
                client.connect(self.ipc_socket)
                msg = json.dumps({"command": cmd}) + "\n"
                client.sendall(msg.encode('utf-8'))
        except Exception: pass

    def mpv_worker(self):
        """Orchestrates MPV playback sequentially."""
        # Wait until the very first track is mixed
        while self.mixed_idx < 0 and not self._quit_flag:
            time.sleep(0.5)
            
        if self._quit_flag: return
        
        first_file = os.path.join(self.mix_dir, f"0_out.wav")
        mpv_cmd = [
            "mpv",
            "--no-video",
            "--gapless-audio=yes",
            "--msg-level=all=no", # Keep terminal brutally clean
            f"--input-ipc-server={self.ipc_socket}",
            first_file
        ]
        
        self.mpv_process = subprocess.Popen(mpv_cmd, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        self.mpv_appended_idx = 0
        
        # Continously append new tracks as they render
        while not self._quit_flag and self.mpv_process.poll() is None:
            if self.mixed_idx > self.mpv_appended_idx:
                next_target = self.mpv_appended_idx + 1
                next_file = os.path.join(self.mix_dir, f"{next_target}_out.wav")
                if os.path.exists(next_file):
                    self.mpv_ipc_command(["loadfile", next_file, "append"])
                    self.mpv_appended_idx = next_target
            time.sleep(1)

    def ui_worker(self):
        """Displays UI status cleanly."""
        printed_idx = -1
        while not self._quit_flag:
            # We must retrieve current playlist index from MPV
            if os.path.exists(self.ipc_socket):
                try:
                    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
                        client.connect(self.ipc_socket)
                        client.sendall(b'{"command": ["get_property", "playlist-pos"]}\n')
                        res = client.recv(1024).decode('utf-8')
                        data = json.loads(res)
                        curr_pos = data.get("data")
                        
                        if curr_pos is not None:
                            curr_idx = int(curr_pos)
                            self.playing_idx = curr_idx
                            if curr_idx != printed_idx:
                                printed_idx = curr_idx
                                if 0 <= printed_idx < len(self.playlist):
                                    print(f"\n{CYAN}━━━━━━━━━━━━━━━━━━━ PLAYING ━━━━━━━━━━━━━━━━━━━━{NC}")
                                    t = self.playlist[printed_idx]['title']
                                    print(f"{GREEN}[{printed_idx + 1}/{len(self.playlist)}]{NC} {YELLOW}{t}{NC}")
                                    if self.last_transition_type and self.mix:
                                        print(f"{DIM}  ⚡ Transition: {self.last_transition_type}{NC}")
                                    if printed_idx + 1 < len(self.playlist):
                                        nt = self.playlist[printed_idx+1]['title']
                                        print(f"{DIM}  ↪ Next: {nt}{NC}")
                                    print(f"{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{NC}")
                except Exception: pass
            time.sleep(1)

    def keyboard_listener(self):
        fd = sys.stdin.fileno()
        is_tty = sys.stdin.isatty()
        
        def on_press(key):
            if self._quit_flag:
                return False
            try:
                if key == keyboard.Key.media_play_pause or key == keyboard.Key.f8:
                    self.mpv_ipc_command(["cycle", "pause"])
                elif key == keyboard.Key.media_next or key == keyboard.Key.f9:
                    self.mpv_ipc_command(["playlist-next"])
                elif key == keyboard.Key.media_previous or key == keyboard.Key.f7:
                    self.mpv_ipc_command(["playlist-prev"])
            except Exception:
                pass

        if keyboard is not None:
            listener = keyboard.Listener(on_press=on_press)
            listener.daemon = True
            listener.start()
            
        # E01 Fix: Don't crash if not running in a terminal
        if not is_tty:
            while not self._quit_flag:
                time.sleep(1)
            return

        old_settings = termios.tcgetattr(fd)
        try:
            tty.setcbreak(sys.stdin.fileno())
            while not self._quit_flag:
                import select
                if select.select([sys.stdin], [], [], 0.5)[0]:
                    ch = sys.stdin.read(1)
                    if ch == ' ':
                        self.mpv_ipc_command(["cycle", "pause"])
                    elif ch == '>' or ch == 'q':
                        self.mpv_ipc_command(["playlist-next"])
                    elif ch == '<':
                        self.mpv_ipc_command(["playlist-prev"])
                    elif ch == 'Q':
                        self._quit_flag = True
                        if self.mpv_process: self.mpv_process.terminate()
                    elif ch == '9':
                        self.mpv_ipc_command(["add", "volume", "-5"])
                    elif ch == '0':
                        self.mpv_ipc_command(["add", "volume", "5"])
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

    def start(self):
        self.fetch_playlist()
        
        # Display mix mode
        if not self.mix:
            mode_str = f"{RED}OFF (--no-mix){NC}"
        elif self.light_mix:
            mode_str = f"{YELLOW}Light Mix (equal-power crossfade){NC}"
        else:
            mode_str = f"{GREEN}Auto-DJ (DecisionEngine + 8 transitions){NC}"
        print(f"\n{CYAN}Mix Mode:{NC} {mode_str}")
        print(f"{YELLOW}Controls: Space=pause, 9/0=volume, >=next, <=previous, q=next song, Shift+q=quit{NC}")
        
        t_dw = threading.Thread(target=self.download_worker, daemon=True)
        t_mx = threading.Thread(target=self.mix_worker, daemon=True)
        t_mp = threading.Thread(target=self.mpv_worker, daemon=True)
        t_ui = threading.Thread(target=self.ui_worker, daemon=True)
        
        t_dw.start()
        t_mx.start()
        
        if self.mix:
            print(f"{DIM}Pre-computing initial transition (takes 5-10 seconds)...{NC}")
        t_mp.start()
        t_ui.start()
        
        self.keyboard_listener()
        success("\nPlayback finished.")


def main():
    parser = argparse.ArgumentParser(description=f"ytstr v{VERSION} — YouTube Playlist Streamer with Auto-DJ", add_help=False)
    parser.add_argument('--list', action='store_true', help='List all saved playlists')
    parser.add_argument('--add', nargs=2, metavar=('NAME', 'URL'), help='Save a playlist with a friendly name')
    parser.add_argument('--remove', type=int, metavar='NUM', help='Remove a saved playlist by index')
    parser.add_argument('--no-shuffle', action='store_true', help='Play tracks in original order')
    parser.add_argument('--no-mix', action='store_true', help='Disable all audio mixing (battery saver)')
    parser.add_argument('--light-mix', action='store_true', help='Simple equal-power crossfade (skip DecisionEngine)')
    parser.add_argument('-h', '--help', action='store_true', help='Show this help message')
    parser.add_argument('target', nargs='?', help='Playlist URL or saved playlist number')
    
    args = parser.parse_args()
    
    if args.help:
        parser.print_help()
        sys.exit(0)
        
    playlists = parse_playlists()
    
    if args.list:
        for i, p in enumerate(playlists):
            print(f"{GREEN}{i+1}.{NC} {p['name']} ({p['url']})")
        sys.exit(0)
    if args.add:
        playlists.append({'name': args.add[0], 'url': args.add[1]})
        save_playlists(playlists)
        success(f"Added playlist: {args.add[0]}")
        sys.exit(0)
    if args.remove:
        try:
            idx = args.remove - 1
            if 0 <= idx < len(playlists):
                removed = playlists.pop(idx)
                save_playlists(playlists)
                success(f"Removed playlist: {removed['name']}")
            else:
                die("Invalid playlist number.")
        except Exception as e:
            die(str(e))
        sys.exit(0)

    playlist_url = args.target
    if not playlist_url:
        info("Select a playlist:")
        for i, p in enumerate(playlists):
            print(f"{GREEN}{i+1}.{NC} {p['name']}")
        try:
            choice = input(f"\n{YELLOW}Enter playlist number:{NC} ")
            idx = int(choice) - 1
            playlist_url = playlists[idx]['url']
        except Exception: die("Invalid input.")
            
    if playlist_url.isdigit():
        playlist_url = playlists[int(playlist_url)-1]['url']

    player = YtstrPlayer(
        playlist_url=playlist_url,
        shuffle=not args.no_shuffle,
        mix=not args.no_mix,
        light_mix=args.light_mix
    )
    
    def cleanup(signum=None, frame=None):
        player._quit_flag = True
        if player.mpv_process:
            try: player.mpv_process.terminate()
            except Exception: pass
        if getattr(player, 'cache_dir', None) and os.path.exists(player.cache_dir):
            shutil.rmtree(player.cache_dir, ignore_errors=True)
        if signum is not None:
            sys.exit(0)
            
    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)
    
    try:
        player.start()
    except Exception:
        cleanup()

if __name__ == "__main__":
    main()
