def ensure_config_dir():
    os.makedirs(os.path.dirname(PLAYLIST_FILE), exist_ok=True)
    if not os.path.exists(PLAYLIST_FILE):
        open(PLAYLIST_FILE, 'w').close()

def parse_playlists() -> List[Dict[str, str]]:
    ensure_config_dir()
    playlists = []
    try:
        with open(PLAYLIST_FILE, 'r') as f:
            for line in f:
                line = line.strip()
                if not line or '|' not in line: continue
                name, url = line.split('|', 1)
                if name and url: playlists.append({"name": name, "url": url})
    except Exception as e: warn(f"Failed to read playlists: {e}")
    return playlists

def save_playlists(playlists: List[Dict[str, str]]):
    ensure_config_dir()
    try:
        with open(PLAYLIST_FILE, 'w') as f:
            for p in playlists: f.write(f"{p['name']}|{p['url']}\n")
    except Exception as e: die(f"Failed to save playlists: {e}")

def get_equal_power_gain(t: float, duration: float, is_fade_in: bool = True) -> float:
    """
    Return a dB gain value for a single point on an equal-power fade curve.

    The curve follows a quarter-cosine (sin²) power law, which keeps the
    *perceived* combined loudness constant during a crossfade — the
    psychoacoustic equivalent of a DJ's equal-power crossfader.

    Parameters
    ----------
    t          : Current time position within the fade, in milliseconds.
    duration   : Total fade duration, in milliseconds.
    is_fade_in : True to compute a fade-in (0 dB → 0 dB), False for fade-out.

    Returns
    -------
    dB gain as a float. Returns −120.0 (effectively silence) when the
    computed multiplier is non-positive.
    """
    x = t / duration if duration > 0 else 0.0
    if not is_fade_in:
        x = 1.0 - x
    multiplier = math.sin(x * math.pi / 2.0)
    if multiplier <= 0:
        return -120.0
    return 20.0 * math.log10(multiplier)


def equal_power_fade(audio: AudioSegment, duration_ms: int, is_fade_in: bool = True) -> AudioSegment:
    """
    Apply an equal-power (sinusoidal) fade to an AudioSegment.

    The audio is processed in 10 ms grains so the gain curve has a high
    enough resolution to sound smooth on standard equipment. Grains outside
    the fade window are returned unmodified.

    Parameters
    ----------
    audio       : The source audio to fade.
    duration_ms : Length of the fade in milliseconds. Clamped to len(audio).
    is_fade_in  : True to fade from silence to full volume; False for the reverse.

    Returns
    -------
    A new AudioSegment with the fade applied.
    """
    if duration_ms <= 0:
        return audio
    duration_ms = min(duration_ms, len(audio))
    chunk_size = 10  # ms per grain — smaller = smoother but slower

    fade_audio = audio[:duration_ms] if is_fade_in else audio[-duration_ms:]
    remainder  = audio[duration_ms:] if is_fade_in else audio[:-duration_ms]

    faded_chunks = []
    for i in range(0, len(fade_audio), chunk_size):
        chunk = fade_audio[i:i + chunk_size]
        t     = i if is_fade_in else i + chunk_size
        gain  = get_equal_power_gain(t, duration_ms, is_fade_in)
        faded_chunks.append(chunk.apply_gain(gain))

    faded_section = sum(faded_chunks) if faded_chunks else AudioSegment.empty()

    return (faded_section + remainder) if is_fade_in else (remainder + faded_section)


def trim_to_energy(audio: AudioSegment, chunk_ms: int = 100, threshold_ratio: float = 0.5) -> AudioSegment:
    """
    Strip low-energy intro and outro regions using RMS thresholding.

    The function scans the track in *chunk_ms* windows from both ends and
    drops contiguous low-energy segments until a chunk exceeds
    ``avg_rms * threshold_ratio``. One extra window is kept on each side
    as a safety buffer.

    This replicates the "energy trim" technique used by professional DJ
    software to ensure every track starts and ends at a musically active
    moment rather than in silence or atmospheric rumble.

    Parameters
    ----------
    audio           : Source audio segment.
    chunk_ms        : Window size for RMS analysis (default 100 ms).
    threshold_ratio : Fraction of the track's average RMS to treat as the
                      threshold (default 0.5 = 50 %).

    Returns
    -------
    A trimmed AudioSegment. Returns the original if no meaningful trim
    can be performed (e.g. completely silent audio).
    """
    avg_rms = audio.rms
    if avg_rms == 0:
        return audio

    threshold = avg_rms * threshold_ratio

    # ── Scan from the front ─────────────────────────────────────────
    start_trim = 0
    for i in range(0, len(audio), chunk_ms):
        if audio[i:i + chunk_ms].rms >= threshold:
            start_trim = max(0, i - chunk_ms)
            break

    # ── Scan from the back ──────────────────────────────────────────
    end_trim = len(audio)
    for i in range(len(audio), 0, -chunk_ms):
        if audio[i - chunk_ms:i].rms >= threshold:
            end_trim = min(len(audio), i + chunk_ms)
            break

    if start_trim >= end_trim:
        return audio  # Safety: avoid returning an empty segment

    intro_cut = start_trim
    outro_cut = len(audio) - end_trim
    if intro_cut > 0 or outro_cut > 0:
        print(f"  -> Stripped {intro_cut}ms intro and {outro_cut}ms outro fluff.", file=sys.stderr)
    return audio[start_trim:end_trim]


def tape_stop_effect(audio: AudioSegment, duration_ms: int) -> AudioSegment:
    """
    Simulate a progressive tape/turntable stop effect.
    
    Slows down the audio over the given duration by progressively dropping
    its frame rate and fading it out, simulating a turntable losing power.
    """
    if len(audio) == 0:
        return audio
        
    duration_ms = min(duration_ms, len(audio))
    tail = audio[-duration_ms:]
    head = audio[:-duration_ms]
    
    steps = 20
    chunk_len = len(tail) // steps
    if chunk_len == 0:
        return audio
        
    parts = []
    for i in range(steps):
        chunk = tail[i*chunk_len : (i+1)*chunk_len]
        ratio = 1.0 - (i / steps) * 0.9  # 100% down to 10% speed
        new_frame_rate = max(int(chunk.frame_rate * ratio), 1000)
        
        try:
            # Spawn a new segment with a lower frame rate, expanding duration and dropping pitch
            slowed = chunk._spawn(chunk.raw_data, overrides={
                "frame_rate": new_frame_rate
            }).set_frame_rate(chunk.frame_rate)
        except Exception:
            slowed = chunk
            
        # Progressive volume drop up to -15dB
        vol_drop = - (i / steps) * 15
        parts.append(slowed + vol_drop)
        
    leftover = tail[steps*chunk_len:]
    if len(leftover) > 0:
        parts.append(leftover - 15)
        
    res = sum(parts) if parts else tail
    # Small fade out at the very end to prevent clicking
    res = res.fade_out(min(200, len(res)))
    return head + res


def tape_start_effect(audio: AudioSegment, duration_ms: int) -> AudioSegment:
    """
    Simulate a turntable/tape powering ON — the reverse of tape_stop_effect.

    The audio begins at ~10 % speed (deep, warped pitch) and ramps up to
    full speed over *duration_ms*, simulating a record player reaching its
    target RPM.  Volume also ramps from −15 dB to 0 dB so the warp-in
    grows progressively louder.
    """
    if len(audio) == 0:
        return audio

    duration_ms = min(duration_ms, len(audio))
    head = audio[:duration_ms]
    tail = audio[duration_ms:]

    steps = 20
    chunk_len = len(head) // steps
    if chunk_len == 0:
        return audio

    parts = []
    for i in range(steps):
        chunk = head[i * chunk_len : (i + 1) * chunk_len]
        # Ramp from 10 % speed at step 0 → 100 % at the last step
        ratio = 0.1 + (i / steps) * 0.9
        new_frame_rate = max(int(chunk.frame_rate * ratio), 1000)

        try:
            sped = chunk._spawn(chunk.raw_data, overrides={
                "frame_rate": new_frame_rate
            }).set_frame_rate(chunk.frame_rate)
        except Exception:
            sped = chunk

        # Progressive volume ramp: −15 dB → 0 dB
        vol_boost = -15 * (1.0 - (i / steps))
        parts.append(sped + vol_boost)

    leftover = head[steps * chunk_len:]
    if len(leftover) > 0:
        parts.append(leftover)  # Already at full speed / volume

    res = sum(parts) if parts else head
    # Small fade in at the very start to prevent clicking
    res = res.fade_in(min(200, len(res)))
    return res + tail


def safe_clamp_fade(duration_ms: int, *tracks: AudioSegment) -> int:
    """
    Clamp a desired fade duration so it never exceeds half of any track's length.

    This prevents the fade windows of two adjacent tracks from overlapping
    each other, which would corrupt the mix structure.

    Parameters
    ----------
    duration_ms : Desired fade length in milliseconds.
    *tracks     : Any number of AudioSegments to clamp against.

    Returns
    -------
    Clamped duration as an int ≥ 0.
    """
    result = duration_ms
    for t in tracks:
        if t is not None and len(t) > 0:
            result = min(result, len(t) // 2)
    return max(result, 0)


def progressive_high_pass(audio: AudioSegment, start_hz: int, end_hz: int, steps: int = 20) -> AudioSegment:
    """
    Apply a progressive high-pass filter sweep across the duration of *audio*.

    Slices the audio into *steps* equal chunks and applies an increasing
    cutoff frequency from *start_hz* to *end_hz*. This simulates the
    effect of a DJ slowly turning a filter knob — the sound becomes
    progressively thinner rather than cutting abruptly.

    Used internally by `trans_bass_swap` and `trans_filter_wash`.

    Parameters
    ----------
    audio     : Source audio to filter.
    start_hz  : Starting cutoff frequency in Hz (low end of the sweep).
    end_hz    : Ending cutoff frequency in Hz (high end of the sweep).
    steps     : Number of discrete filter steps (default 20).

    Returns
    -------
    A new AudioSegment with the progressive filter applied.
    """
    if len(audio) == 0 or steps <= 0:
        return audio
    step_len = len(audio) // steps
    if step_len == 0:
        return audio

    parts = []
    for i in range(steps):
        ratio   = i / max(steps - 1, 1)
        cutoff  = int(start_hz * (end_hz / start_hz) ** ratio)
        cutoff  = max(cutoff, 20)  # pydub's minimum supported cutoff
        chunk   = audio[i * step_len:(i + 1) * step_len]
        try:
            chunk = high_pass_filter(chunk, cutoff)
        except Exception:
            pass  # Preserve chunk unfiltered on unexpected pydub failure
        parts.append(chunk)

    # Handle any leftover samples from integer division
    leftover = audio[steps * step_len:]
    if len(leftover) > 0:
        try:
            leftover = high_pass_filter(leftover, end_hz)
        except Exception:
            pass
        parts.append(leftover)

    return sum(parts) if parts else audio


