class DecisionEngine:
    """
    Automatic DJ transition selector based on spectral energy analysis.

    For each track pair, the engine analyses a 5-second window at the end
    of the outgoing track and the start of the incoming track. It extracts
    four features and applies a priority-ordered waterfall of rules to
    select the transition style that best suits each specific handoff.

    Features
    --------
    rms         : Total signal energy (mono amplitude).
    bass_rms    : Energy in the sub-250 Hz band (kick drums, bass guitar).
    treble_rms  : Energy above 2 kHz (hi-hats, vocals, cymbals).
    variance    : How much the energy fluctuates over 500 ms windows.
                  Low variance = steady, repetitive groove.
                  High variance = dynamic, ever-changing energy.

    Decision Rules (evaluated in priority order)
    --------------------------------------------
    1. Incoming is ≥ 1.8× louder than outgoing  →  rise
       (Strong energy surge — progressive swell emphasises the drop.)
    2. Both tracks are > 40 % bass               →  bass_swap
       (Prevent muddy low-end collisions via HP sweep + LF kill.)
    3. Outgoing treble > 1.8× its bass           →  filter_wash
       (Outgoing is treble-dominated — sweep it away with resonance.)
    4. Outgoing is < 25 % of incoming energy     →  cut_in
       (Outgoing is nearly inaudible — hard cut, no point blending.)
    5. Outgoing energy variance > 0.4 × rms²    →  melt
       (Chaotic ending — dissolve it with echo wash rather than fade.)
    6. Both tracks variance < 0.08 × rms²       →  blend
       (Steady-groove tracks benefit from the long 10 s overlap.)
    7. Default                                    →  fade
    """

    ANALYSIS_WINDOW_MS = 5000

    def _analyze(self, chunk: AudioSegment) -> tuple:
        """
        Extract (rms, bass_rms, treble_rms, energy_variance) from a chunk.

        Energy variance is computed by splitting the chunk into 500 ms
        windows, measuring the RMS of each, and returning the population
        variance. This quantifies how "dynamic" or "chaotic" the energy
        profile is.
        """
        if chunk is None or len(chunk) == 0:
            return 0.0, 0.0, 0.0, 0.0

        rms = float(chunk.rms)

        try:
            bass = float(low_pass_filter(chunk, 250).rms)
        except Exception:
            bass = rms
        try:
            treble = float(high_pass_filter(chunk, 2000).rms)
        except Exception:
            treble = rms

        # Population variance of per-window RMS values
        window_ms = 500
        energies = [float(chunk[i:i + window_ms].rms)
                    for i in range(0, len(chunk), window_ms)]
        if len(energies) > 1:
            mean     = sum(energies) / len(energies)
            variance = sum((e - mean) ** 2 for e in energies) / len(energies)
        else:
            variance = 0.0

        return rms, bass, treble, variance

    def select_transition(self, current_song: AudioSegment,
                          next_song: AudioSegment) -> str:
        """
        Return the name of the best-fit transition for this track pair.

        Parameters
        ----------
        current_song : The outgoing AudioSegment.
        next_song    : The incoming AudioSegment.

        Returns
        -------
        A transition name string (key of the TRANSITIONS dict).
        Falls back to "fade" when inputs are None or RMS is zero.
        """
        if current_song is None or next_song is None:
            return "fade"

        win_a = min(self.ANALYSIS_WINDOW_MS, len(current_song))
        win_b = min(self.ANALYSIS_WINDOW_MS, len(next_song))
        a_rms, a_bass, a_treble, a_var = self._analyze(current_song[-win_a:])
        b_rms, b_bass, b_treble, b_var = self._analyze(next_song[:win_b])

        if a_rms == 0 or b_rms == 0:
            return "fade"

        # Rule 1: Incoming drop / energy surge
        if b_rms > a_rms * 1.8:
            return "rise"

        # Rule 2: Very different tracks → tape_stop (prevent clashing overlaps)
        # Triggers when tracks diverge significantly in:
        #   - overall energy (RMS ratio > 3×)
        #   - energy dynamics (variance ratio > 4×)
        #   - frequency balance (bass/treble profile ratio > 2.5×)
        rms_ratio = max(a_rms, 1) / max(b_rms, 1)
        a_profile = a_bass / max(a_treble, 1)
        b_profile = b_bass / max(b_treble, 1)
        if (rms_ratio > 3.0 or rms_ratio < (1.0 / 3.0) or
            max(a_var, 1) / max(b_var, 1) > 4.0 or
            max(b_var, 1) / max(a_var, 1) > 4.0 or
            max(a_profile, 0.1) / max(b_profile, 0.1) > 2.5 or
            max(b_profile, 0.1) / max(a_profile, 0.1) > 2.5):
            return "tape_stop"

        # Rule 3: Both tracks are bass-heavy → prevent low-end mud
        if (a_bass / a_rms) > 0.40 and (b_bass / b_rms) > 0.40:
            return "bass_swap"

        # Rule 3: Outgoing is treble-dominated / cluttered → wash away
        if a_treble > a_bass * 1.8 and a_bass > 0:
            return "filter_wash"

        # Rule 4: Outgoing is nearly silent → hard cut, no point blending
        if a_rms < b_rms * 0.25:
            return "cut_in"

        # Rule 5: Outgoing energy is chaotic → dissolve with echoes
        if a_var > (a_rms ** 2) * 0.4:
            return "melt"

        # Rule 6: Both tracks have a steady, repetitive groove → long blend
        if a_var < (a_rms ** 2) * 0.08 and b_var < (b_rms ** 2) * 0.08:
            return "blend"

        # Default: tape crossfade — short, safe, works with any edge case
        return "tape_stop"



